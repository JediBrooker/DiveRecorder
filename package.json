    "test": "node --test test/syntax.test.js test/calc.test.js test/score-trim.test.js test/dive-label.test.js test/venue-daktronics-bridge.test.js test/venue-state.test.js test/coach-alerts.test.js test/schedule-conflicts.test.js test/schedule-reflow.test.js test/server-i18n.test.js test/synchro-consent.test.js test/i18n-parity.test.js test/body-scroll-lock.test.js test/schedule-conflicts.integration.test.js test/integration.test.js",
