    "test:e2e": "playwright test",
    "test:e2e:docs": "E2E_DOCS=1 playwright test test/e2e/wiki-screenshots.spec.js --workers=1",
    "test:e2e:visual": "playwright test test/e2e/visual-regression.spec.js",
    "test:e2e:mobile": "playwright test --project=mobile-safari",
    "test:e2e:cross-browser": "playwright test --project=mobile-safari --project=mobile-chrome --project=firefox",
    "test:e2e:profile": "PLAYWRIGHT_JSON_OUTPUT_NAME=/tmp/divinghq-playwright-profile.json playwright test --reporter=json",
    "test:e2e:headed": "PW_SLOWMO=300 playwright test --headed",
    "migrate": "node scripts/migrate.js",
    "translate": "node scripts/translate-locales.js",
    "venue:daktronics": "node scripts/venue-daktronics-bridge.js"
  },
