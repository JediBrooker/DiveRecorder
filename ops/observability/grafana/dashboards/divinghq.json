{
  "title": "DivingHQ",
  "uid": "dive-recorder",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["dive-recorder"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Score submissions / minute",
      "description": "Should spike during a meet, ~0 between.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(dive_recorder_scores_submitted_total[1m])) * 60",
          "legendFormat": "scores/min"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected sockets",
      "description": "Currently-open Socket.IO connections.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dive_recorder_socket_connections",
          "legendFormat": "sockets"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB pool waiting",
      "description": "Saturation signal — anything sustained > 0 means the pool is too small.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dive_recorder_db_pool_waiting",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scoreboard cache hit ratio",
      "description": "Should be ≥0.9 during an active meet.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(dive_recorder_scoreboard_cache_hits_total[5m]) / clamp_min(rate(dive_recorder_scoreboard_cache_hits_total[5m]) + rate(dive_recorder_scoreboard_cache_misses_total[5m]), 0.0001)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate by route",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(dive_recorder_http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(dive_recorder_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dive_recorder_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(dive_recorder_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Score submissions: accepted vs rejected",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 25, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(dive_recorder_scores_submitted_total[1m])",
          "legendFormat": "accepted"
        },
        {
          "refId": "B",
          "expr": "sum by (reason) (rate(dive_recorder_scores_rejected_total[1m]))",
          "legendFormat": "rejected: {{reason}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Process resident memory",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dive_recorder_process_resident_memory_bytes",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent application logs",
      "description": "Filter via the query bar (e.g. add | level=\"error\"). Click a row to expand all structured fields.",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"dive-recorder\"} | json"
        }
      ]
    }
  ]
}
