# Copy this to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# --- Server ---
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=diverecorder
DB_USER=postgres
DB_PASSWORD=

# --- JWT ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY=8h

# --- Email (optional — leave SMTP_HOST blank to disable email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
