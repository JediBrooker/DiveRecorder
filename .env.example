# =============================================================
# DivingHQ — environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored —
# never commit it. The server fail-closes on missing JWT_SECRET;
# everything else has sensible defaults but you should set them
# explicitly in production.
#
# Generate a strong JWT secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# =============================================================

# --- Server ---
PORT=3000
# Where the SPA + API speak from. Used by CORS + Socket.IO.
CORS_ORIGIN=http://localhost:5173
# Public base URL of the deployed app (used in password-reset
# links and meet-program PDFs). Defaults to CORS_ORIGIN if unset.
APP_BASE_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# DATABASE_URL takes precedence if set. Otherwise the libpq-style
# DB_* vars below are used.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=divinghq
DB_USER=postgres
DB_PASSWORD=

# --- JWT (REQUIRED) ---
# Boot fails closed if unset or equal to the well-known placeholder.
# Warning emitted at <32 chars; rotate to >=32 random chars in prod.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY=8h

# --- Email (optional) ---
# When SMTP_HOST is blank every email helper silently no-ops, so
# the app still runs in dev. To wire up password resets / role-
# decision notifications / meet emails fill these in.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From-address shown to recipients. Defaults to SMTP_USER.
SMTP_FROM=

# --- Metrics (optional) ---
# When set, the /metrics Prometheus scrape endpoint requires
# `Authorization: Bearer <token>` and rejects everything else with
# a 401. When unset, /metrics is open — relies on firewall / reverse
# proxy ACL. Recommend setting in any deployment where Prometheus
# scrapes across the network.
METRICS_TOKEN=

# --- Web Push / VAPID (optional) ---
# Generate a key pair once per deployment:
#     node scripts/generate-vapid-keys.js
# Rotating these invalidates every existing browser subscription,
# so set once and persist. When VAPID_PUBLIC_KEY is unset, the
# push backend silently no-ops — the app still runs and falls
# through to the in-app socket banner. SUBJECT is the contact
# the push service uses to reach you if your sender misbehaves.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com
