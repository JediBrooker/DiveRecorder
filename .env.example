# =============================================================
# DiveRecorder — environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored —
# never commit it. The server fail-closes on missing JWT_SECRET;
# everything else has sensible defaults but you should set them
# explicitly in production.
#
# Generate a strong JWT secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# =============================================================

# --- Server ---
PORT=3000
# Where the SPA + API speak from. Used by CORS + Socket.IO.
CORS_ORIGIN=http://localhost:5173
# Public base URL of the deployed app (used in password-reset
# links and meet-program PDFs). Defaults to CORS_ORIGIN if unset.
APP_BASE_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# DATABASE_URL takes precedence if set. Otherwise the libpq-style
# DB_* vars below are used.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=diverecorder
DB_USER=postgres
DB_PASSWORD=

# --- JWT (REQUIRED) ---
# Boot fails closed if unset or equal to the well-known placeholder.
# Warning emitted at <32 chars; rotate to >=32 random chars in prod.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY=8h

# --- Email (optional) ---
# When SMTP_HOST is blank every email helper silently no-ops, so
# the app still runs in dev. To wire up password resets / role-
# decision notifications / meet emails fill these in.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From-address shown to recipients. Defaults to SMTP_USER.
SMTP_FROM=
